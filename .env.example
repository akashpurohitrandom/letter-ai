# The password your special someone will use to unlock the site
SITE_PASSWORD=change-me

# The password for the very first "door" gate page
DOOR_PASSWORD=july2026

# Random long random string, used to sign the unlock cookie (any long random text)
AUTH_SECRET=change-this-to-a-long-random-string

# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The Spotify playlist to embed — copy the ID from the playlist share link
# e.g. https://open.spotify.com/playlist/37i9dQZF1DXcBWIGoYBM5M -> 37i9dQZF1DXcBWIGoYBM5M
# Must be NEXT_PUBLIC_ since it's used directly in the browser (no API keys needed).
NEXT_PUBLIC_SPOTIFY_PLAYLIST_ID=your-playlist-id
